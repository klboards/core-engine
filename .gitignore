# Stack-agnostic until the stack is chosen (open #8). Add stack-specific
# ignores here only when this repo's stack is decided.

# Local Claude config (personal, per-machine)
.claude/settings.local.json

# Secrets / env
.env
.env.*
*.pem
*.key

# OS / editor cruft
.DS_Store
*.swp
*~

# Rust build artifacts (stack decided = Rust, ADR-0010). This checkout normally builds into the shared
# CARGO_TARGET_DIR (forge/target), but a standalone `cargo` invocation falls back to ./target.
/target
