{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "extraKnownMarketplaces": {
    "klboards": {
      "source": {
        "source": "github",
        "repo": "klboards/klboards"
      }
    }
  },
  "enabledPlugins": {
    "klboards-org@klboards": true
  },
  "permissions": {
    "allow": [
      "Bash(gh repo view *)",
      "Bash(gh pr view *)",
      "Bash(gh pr list *)",
      "Bash(gh issue view *)",
      "Bash(gh issue list *)",
      "Bash(gh auth status)"
    ]
  }
}
